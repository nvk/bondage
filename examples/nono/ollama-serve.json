{
  "extends": "default",
  "meta": {
    "name": "ollama-serve",
    "description": "Ollama server with writable local model state"
  },
  "policy": {
    "add_deny_access": [
      "/Volumes"
    ],
    "add_allow_readwrite": [
      "$HOME/.ollama"
    ]
  },
  "workdir": {
    "access": "readwrite"
  }
}
