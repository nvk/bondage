[global]
envchain = /opt/homebrew/bin/envchain
envchain_fp = sha256:replace-me
nono = /opt/homebrew/bin/nono
nono_fp = sha256:replace-me
nono_profile_root = /Users/nvk/src-repo/.dotfiles/ai/nono/profiles
touchid = /opt/homebrew/bin/touchid-check
touchid_fp = sha256:replace-me
tool_root = /Users/nvk/.bondage/tools

[profile "codex"]
use_envchain = false
use_nono = true
nono_profile = custom-codex
touch_policy = none
target_kind = native
target = /Users/nvk/.bondage/tools/codex/0.125.0/codex-aarch64-apple-darwin
target_fp = sha256:replace-me
nono_allow_cwd = true
nono_allow_file = /dev/tty
nono_allow_file = /dev/null
nono_read_file = /dev/urandom
env_set = GIT_CONFIG_GLOBAL=/Users/nvk/src-repo/.dotfiles/ai/gitconfig-sandbox
env_set = GIT_TERMINAL_PROMPT=0
env_command = GH_TOKEN=/opt/homebrew/bin/gh auth token
env_command = GITHUB_TOKEN=/opt/homebrew/bin/gh auth token

[profile "pi"]
namespace = openai-oc,gemini-a,xai-n
use_envchain = true
use_nono = true
nono_profile = custom-pi
touch_policy = prompt
target_kind = script
target = /Users/nvk/.bondage/tools/pi/1.2.3/dist/cli.js
target_fp = sha256:replace-me
interpreter = /Users/nvk/.bondage/tools/runtimes/node/22.12.0/bin/node
interpreter_fp = sha256:replace-me
package_root = /Users/nvk/.bondage/tools/pi/1.2.3
package_tree_fp = sha256:replace-me
nono_allow_cwd = true
nono_allow_file = /dev/tty
nono_allow_file = /dev/null
nono_read_file = /dev/urandom
env_set = GIT_CONFIG_GLOBAL=/Users/nvk/src-repo/.dotfiles/ai/gitconfig-sandbox
env_command = GH_TOKEN=/opt/homebrew/bin/gh auth token
env_command = GITHUB_TOKEN=/opt/homebrew/bin/gh auth token
ensure_dir = /Users/nvk/.pi

[profile "pi-rawdog"]
namespace = openai-oc,gemini-a,xai-n
use_envchain = true
use_nono = false
touch_policy = prompt
target_kind = script
target = /Users/nvk/.bondage/tools/pi/1.2.3/dist/cli.js
target_fp = sha256:replace-me
interpreter = /Users/nvk/.bondage/tools/runtimes/node/22.12.0/bin/node
interpreter_fp = sha256:replace-me
package_root = /Users/nvk/.bondage/tools/pi/1.2.3
package_tree_fp = sha256:replace-me
env_set = GIT_CONFIG_GLOBAL=/Users/nvk/src-repo/.dotfiles/ai/gitconfig-sandbox
env_command = GH_TOKEN=/opt/homebrew/bin/gh auth token
env_command = GITHUB_TOKEN=/opt/homebrew/bin/gh auth token
ensure_dir = /Users/nvk/.pi
